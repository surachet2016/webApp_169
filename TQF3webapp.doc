      <table width="100%" border="0" cellspacing="0" cellpadding="0">
         <tbody>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="center"></td>
               <td align="center">&nbsp;</td>
            </tr>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="left">&nbsp;</td>
               <td align="center">&nbsp;</td>
            </tr>
            <tr>
               <td width="10%" align="center">&nbsp;</td>
               <td align="left"><strong>3. จำนวนชั่วโมงต่อสัปดาห์ที่อาจารย์ให้คำปรึกษาและแนะนำทางวิชาการแก่นักศึกษาเป็นรายบุคคล</strong></td>
