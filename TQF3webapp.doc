div.must_same_page{
   /* บังคับให้ เนื้อหาใน div ต้องอยู่หน้าเดียวกัน และแก้ปัญหา การย่อ font อัตโนมัต*/
   page-break-inside: avoid;
   
}
      </style>
   </head>

<body>
   <div width="210mm" style="width: 210mm">
      <table width="100%" border="0" cellspacing="0" cellpadding="0">
         <tbody>
            <tr>
               <td width="10%" align="center">&nbsp;</td>
               <td align="center">
                  <h2>หมวดที่ 7 <strong>การประเมินและปรับปรุงการดำเนินการของรายวิชา</strong></h2>
               </td>
               <td width="10%" align="center">&nbsp;</td>
            </tr>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="left">&nbsp;</td>
               <td align="center">&nbsp;</td>
            </tr>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="left"><strong>1. กลยุทธ์การประเมินประสิทธิผลของรายวิชาโดยนักศึกษา</strong></td>
               <td align="center">&nbsp;</td>
            </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">1.1 การสนทนากลุ่มระหว่างผู้สอนและผู้เรียน &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">1.2 การสังเกตการณ์จากพฤติกรรมของผู้เรียน &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">1.3 แบบประเมินผู้สอนและแบบประเมินรายวิชาผ่านระบบออนไลน์ของมหาวิทยาลัย &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
            
            <tr>
               <td align="center">&nbsp;</td>
               <td align="left">&nbsp;</td>
               <td align="center">&nbsp;</td>
            </tr>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="left"><strong>2. กลยุทธ์การประเมินการสอน</strong></td>
               <td align="center">&nbsp;</td>
            </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">2.1 คณะกำหนดให้มีการประเมินการสอนโดยคณะกรรมการประเมินการสอนที่แต่งตั้งโดยผู้บริหารคณะวิทยาการจัดการ &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">2.2 การตรวจสอบผลการเรียนรู้ของนักศึกษาเทียบกับ CLOs ที่กำหนด &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                        <tr>
               <td align="center">&nbsp;</td>
               <td align="left">&nbsp;</td>
               <td align="center">&nbsp;</td>
            </tr>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="left"><strong>3.  การปรับปรุงการสอน</strong></td>
               <td align="center">&nbsp;</td>
            </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">3.1 จัดกิจกรรมระดมสมองและหาข้อมูลเพิ่มเติมเพื่อปรับปรุงการสอน &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">3.2 ปรับปรุงเครื่องมือ เฟรมเวิร์ก และตัวอย่างโครงงานให้ทันสมัยตามเทคโนโลยีการพัฒนาเว็บ &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                        <tr>
               <td align="center">&nbsp;</td>
               <td align="left">&nbsp;</td>
               <td align="center">&nbsp;</td>
            </tr>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="left"><strong>4. การทวนสอบมาตรฐานผลสัมฤทธิ์ของนักศึกษาในรายวิชา</strong></td>
               <td align="center">&nbsp;</td>
            </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">4.1 ทวนสอบผลสัมฤทธิ์รายหัวข้อจากการสุ่มตรวจชิ้นงานเว็บ ใบงาน และผลการทดสอบย่อย &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">4.2 ตั้งคณะกรรมการในสาขาวิชาตรวจสอบผลการประเมิน ข้อสอบ รายงาน และวิธีการให้คะแนน &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                        <tr>
               <td align="center">&nbsp;</td>
               <td align="left">&nbsp;</td>
               <td align="center">&nbsp;</td>
            </tr>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="left"><strong>5.  การดำเนินการทบทวนและการวางแผนปรับปรุงประสิทธิผลของรายวิชา</strong></td>
               <td align="center">&nbsp;</td>
            </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">5.1 ปรับปรุงรายวิชาทุก 3 ปี หรือตามข้อเสนอแนะและผลการทวนสอบมาตรฐานผลสัมฤทธิ์ตามข้อ 4 &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                           <tr>
                  <td align="center">&nbsp;</td>
                  <td align="right">
                     <table width="95%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                           <tr>
                              <td align="left">5.2 ปรับปรุงเนื้อหาและกิจกรรมให้สอดคล้องกับพัฒนาการของเทคโนโลยีเว็บและความต้องการของอุตสาหกรรม &nbsp;</td>
                           </tr>
                        </tbody>
                     </table>
                  </td>
                  <td align="center">&nbsp;</td>
               </tr>
                     </tbody>
      </table>

   </div>
</body>






