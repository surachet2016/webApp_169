div.must_same_page{
   /* บังคับให้ เนื้อหาใน div ต้องอยู่หน้าเดียวกัน และแก้ปัญหา การย่อ font อัตโนมัต*/
   page-break-inside: avoid;
   
}
      </style>
   </head>

<body>
         <br clear=all style='page-break-before:always;mso-break-type:section-break'>
      <div width="297mm" style="width: 297mm" class="WordSection2">
