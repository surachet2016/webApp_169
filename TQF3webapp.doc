            </tr>
            <tr>
               <th width="20%" scope="col"><strong>บรรยาย</strong></th>
               <th width="20%" scope="col"><strong>การฝึกปฏิบัติ/<br />การฝึกงาน</strong></th>
               <th width="20%" scope="col"><strong>การศึกษาด้วย<br />ตนเอง</strong></th>
               <th width="20%" scope="col"><strong>สอนเสริมรายวิชา</strong></th>
            </tr>

         </thead>
         <tbody>
            <tr>
               <td align="center">3.0 (2-2-5)</td>
               <td align="center">30.00</td>
               <td align="center">30.00</td>
