<head>
   <meta charset="UTF-8">
   <title>มคอ.3 หมวดที่ 5 แผนการสอนและการประเมินผล</title>
   <style type="text/css">
      body {
         font-family: "TH SarabunPSK", THSarabun, Tahoma;
         font-size: 18px;
      }

      table {
         overflow: wrap;
      }

      h1 {
         font-size: 32px;
         font-weight: bold;
      }

      h2 {
         font-size: 24px;
         font-weight: bold;
         margin-bottom: 0.01em;
      }

      h3 {
         font-size: 20px;
         font-weight: bold;
      }

      h4 {
         font-size: 18px;
         font-weight: bold;
      }

      .tabBorder thead tr th,
      .tabBorder tbody tr td {
         border: 0.01em solid black;
         padding: 0.2em;
         font-size: 13pt;
      }

      .tabGrade thead tr th,
      .tabGrade tbody tr td {
         border: 0.01em solid black;
         padding: 0.2em;
         font-size: 13pt;
      }

      td.paragraph1 {
         padding-left: 10mm;
      }

      td.paragraph2 {
         padding-left: 20mm;
      }
   </style>
         <style type="text/css">
          body{
    font-family: "TH SarabunPSK", THSarabun;
    font-size: 20px;
 }
table{
    overflow: wrap;
 }
h1 {
   font-size: 32px;
   font-weight: bold;
}
h2 {
   font-size: 24px;
   font-weight: bold;
   margin-bottom: 0.01em;
}
h3 {
   font-size: 20px;
   font-weight: bold;
}
h4 {
   font-size: 20px;
   font-weight: bold;
}

 div.A4_P {
   width: 210mm;
}

div.A4_L {
   width: 297mm;
}

.tabBorder thead tr th,  .tabBorder tbody tr td,  .tabBorder tfoot tr td {
   border: 0.01em solid black;
}
td.cellMargin {
   width: 5%;
}

table.border-around {
    border-collapse: collapse;
    border: 0.01em solid black;
}

td.border-around {
    border-collapse: collapse;
    border: 0.01em solid black;
}
th.border-around {
    border-collapse: collapse;
    border: 0.01em solid black;
}
 .underline {
    border-bottom: 0.01em dotted black;
 }
 .top-buttom-row{
    height:10px;
 }

 .bg_black{
    background: black;
 }
 .bg_gray{
    background: gray;
 }
 .border_top, .border_top td{
    border-top: solid 0.01em black !important;
 }
 .border_top_bottom, .border_top_bottom td{
    border-top: solid 0.01em black !important;
    border-bottom: solid 0.01em black !important;
 }
 .border_bottom, .border_bottom td{
    border-bottom: solid 0.01em black !important;
 }
 .border_left, .border_left td{
    border-left: solid 0.01em black !important;
 }
 .border_left_right, .border_left_right td{
    border-left: solid 0.01em black !important;
    border-right: solid 0.01em black !important;
 }
 .border_right, .border_right td{
    border-right: solid 0.01em black !important;
 }

.border_no, .border_no tbody tr td, .border_no thead tr th{
   border: none !important;
}

table.tableBorderAround {
    border-collapse: collapse;
    border: 1px solid black;
}
div.must_same_page{
   /* บังคับให้ เนื้อหาใน div ต้องอยู่หน้าเดียวกัน และแก้ปัญหา การย่อ font อัตโนมัต*/
   page-break-inside: avoid;
   
}
      </style>
   </head>

<body>
   <div width="210mm" style="width: 210mm">
      <table width="100%" border="0" cellspacing="0" cellpadding="0">
         <tbody>
            <tr>
               <td width="10%" align="center">&nbsp;</td>
               <td align="center">
                  <h2>หมวดที่ 5 <strong>แผนการสอนและการประเมินผล</strong></h2>
               </td>
               <td width="10%" align="center">&nbsp;</td>
            </tr>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="center">&nbsp;</td>
               <td align="center">&nbsp;</td>
            </tr>
            <tr>
               <td align="center">&nbsp;</td>
               <td align="left"><strong>1. แผนการสอน </strong>(จัดทำแผนการสอนไม่น้อยกว่า 15 สัปดาห์)</td>
               <td align="center">&nbsp;</td>
            </tr>
         </tbody>
      </table>
      <table width="90%" border="0" align="center" cellpadding="0" cellspacing="0" class="tabBorder">
         <thead>
            <tr>
               <th style="width: 15mm;" rowspan="2" scope="col"><strong>สัปดาห์<br>ที่/<br>
                     คาบที่</strong></th>
               <th rowspan="2" scope="col"><strong>หัวข้อ/รายละเอียด</strong></th>
               <th colspan="2" scope="col"><strong>ชั่วโมงสอนต่อสัปดาห์</strong></th>
               <th style="width: 15mm;" rowspan="2" scope="col"><strong>ความ<br>สอดคล้อง<br>กับ CLOs</strong></th>
               <th style="width: 15mm;" rowspan="2" scope="col"><strong>กิจกรรม<br>
                     การสอน</strong></th>
               <th style="width: 15mm;" rowspan="2" scope="col"><strong>สื่อที่ใช้ในการ<br>
                     สอน</strong></th>
               <th style="width: 40mm;" rowspan="2" scope="col"><strong>อาจารย์<br>ผู้สอน</strong></th>
            </tr>
            <tr>
               <th style="width:15mm;" scope="col"><strong>ทฤษฎี</strong></th>
               <th style="width:15mm;" scope="col"><strong>ปฏิบัติ</strong></th>
            </tr>
         </thead>
         <tbody>
                           <tr>
                  <td align="center" valign="top">&nbsp;1</td>
                  <td valign="top">แนะนำรายวิชา ภาพรวมการพัฒนาเว็บแอปพลิเคชัน สถาปัตยกรรม Client-Server และโพรโทคอล HTTP </td>
                  <td align="center" valign="top">2</td>
                  <td align="center" valign="top">2</td>
                  <td valign="top">CLO1 </td>
                  <td valign="top">บรรยาย, อภิปราย </td>
                  <td valign="top">สไลด์ </td>
                  <td valign="top">อาจารย์ ดร.สุรเชษฐ์ สังขพันธ์</td>
               </tr>
                           <tr>
                  <td align="center" valign="top">&nbsp;2</td>
                  <td valign="top">ทบทวน HTML, CSS, JavaScript และการจัดวางหน้าเว็บ (Front-end) [ปฏิบัติ 1] </td>
                  <td align="center" valign="top">2</td>
                  <td align="center" valign="top">2</td>
                  <td valign="top">CLO4 </td>
                  <td valign="top">ปฏิบัติการ </td>
                  <td valign="top">ใบงาน, IDE </td>
                  <td valign="top">อาจารย์ ดร.สุรเชษฐ์ สังขพันธ์</td>
               </tr>
                           <tr>
                  <td align="center" valign="top">&nbsp;3</td>
                  <td valign="top">พื้นฐานภาษาฝั่งเซิร์ฟเวอร์ (Server-side script) และการติดตั้งสภาพแวดล้อม [ปฏิบัติ 2] </td>
                  <td align="center" valign="top">2</td>
                  <td align="center" valign="top">2</td>
                  <td valign="top">CLO3 </td>
                  <td valign="top">ปฏิบัติการ </td>
                  <td valign="top">ใบงาน, Web Server </td>
                  <td valign="top">อาจารย์ ดร.สุรเชษฐ์ สังขพันธ์</td>
               </tr>
                           <tr>
                  <td align="center" valign="top">&nbsp;4</td>
                  <td valign="top">ตัวแปร โครงสร้างควบคุม ฟังก์ชันฝั่งเซิร์ฟเวอร์ และการรับส่งข้อมูลฟอร์ม (GET/POST) [ปฏิบัติ 3] </td>
                  <td align="center" valign="top">2</td>
                  <td align="center" valign="top">2</td>
                  <td valign="top">CLO3 </td>
                  <td valign="top">ปฏิบัติการ </td>
                  <td valign="top">ใบงาน, IDE </td>
                  <td valign="top">อาจารย์ ดร.สุรเชษฐ์ สังขพันธ์</td>
               </tr>
                           <tr>
                  <td align="center" valign="top">&nbsp;5</td>
                  <td valign="top">การออกแบบและเชื่อมต่อฐานข้อมูล (SQL) [ปฏิบัติ 4] </td>
                  <td align="center" valign="top">2</td>
                  <td align="center" valign="top">2</td>
                  <td valign="top">CLO2, CLO3 </td>
                  <td valign="top">ปฏิบัติการ </td>
